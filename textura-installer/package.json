{
  "name": "textura-installer",
  "version": "0.1.0",
  "description": "Textura-Based Desktop Installer Reference Architecture — exploratory spike",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "compile:electron": "tsc --project tsconfig.electron.json",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run compile:electron && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "npm run build && electron-builder",
    "mock-api": "tsx backend/mock-api.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.7",
    "express": "^4.21.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}